{
  "framework": null,
  "rewrites": [
    {
      "source": "/storage/v1/object/public/:bucket/:path*",
      "destination": "https://xnkjdmvbeqfqsoskidoh.supabase.co/storage/v1/object/public/:bucket/:path*"
    }
  ],
  "headers": [
    {
      "source": "/storage/v1/object/public/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/vendor/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/app.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
